AI_PROVIDER=zero-cost
AI_MODEL=zero-cost-rule-engine
AI_FALLBACK_PROVIDER=mock

AI_ANALYZE_PROVIDER=zero-cost
AI_ANALYZE_MODEL=
AI_INTEREST_PROVIDER=zero-cost
AI_INTEREST_MODEL=
AI_OUTPUT_PROVIDER=zero-cost
AI_OUTPUT_MODEL=

CRON_AI_PROVIDER=zero-cost
CRON_AI_MODEL=
CRON_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=

AI_BASE_URL=
AI_API_KEY=

OLLAMA_BASE_URL=http://localhost:11434

AI_LOG_TO_DB=true
AI_LOG_FILE=

# Production now uses PostgreSQL. Put your Neon pooled connection string here.
# Example format only; do not commit real credentials:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 默认不需要任何第三方 AI API Key。
# zero-cost provider 不调用外部 API。
# openai / openai-compatible 是可选高级模式，不是必需。
# cron 默认使用 zero-cost，避免后台自动产生 API 费用。
# Ollama 是本地可选模式，不是必需。
# 数据库已从 SQLite 迁移为 PostgreSQL；生产环境推荐 Neon Postgres。